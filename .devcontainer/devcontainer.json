{
  "name": "Argentum — Silver Trading Assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": {
      "label": "Argentum Frontend",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "Argentum API",
      "onAutoForward": "ignore"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3"
      }
    }
  },

  "remoteEnv": {
    "NEXT_PUBLIC_API_BASE": "https://${localEnv:CODESPACE_NAME}-8000.${localEnv:GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}",
    "PYTHONUNBUFFERED": "1"
  }
}

# Скопируйте этот файл в .env и заполните своими значениями.
# .env должен быть в .gitignore — НИКОГДА не коммитить!
# Этот файл (.env.example) — публичный шаблон. НЕ кладите сюда настоящие токены!

# Tinkoff Invest API токен (sandbox-only права!)
# Получить: https://www.tinkoff.ru/invest/settings
TINKOFF_TOKEN=t.YOUR_NEW_SANDBOX_TOKEN_HERE

# Опционально: режим работы (sandbox|production)
TINKOFF_MODE=sandbox

# Опционально: тикер для торговли серебром
# Варианты: SLV (US ETF), GLDM, SLVM, или FIGI напрямую
TINKOFF_SILVER_TICKER=SLV
